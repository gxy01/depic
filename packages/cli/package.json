{
  "name": "@depic/cli",
  "version": "0.1.0-beta.1",
  "description": "CLI for depic — JS/TS dependency analysis",
  "license": "MIT",
  "type": "module",
  "bin": {
    "depic": "./dist/cli.js"
  },
