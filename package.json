{
  "name": "depic",
  "private": true,
  "description": "JS/TS code dependency analysis library",
  "scripts": {
    "test": "vitest",
    "test:run": "vitest run",
    "build": "rolldown -c rolldown.config.mjs && pnpm --filter @depic/core build && pnpm --filter @depic/web build && pnpm --filter @depic/cli build && pnpm --filter depic-vscode build",
    "typecheck": "pnpm -r typecheck"
  },
  "devDependencies": {
    "rolldown": "^1.1.1",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  },
  "packageManager": "pnpm@10.11.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "@swc/core",
      "esbuild"
    ]
  }
}
