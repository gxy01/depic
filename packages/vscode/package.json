{
  "name": "depic-vscode",
  "displayName": "Depic — Dependency Visualizer",
  "version": "0.1.0",
  "private": true,
  "description": "Interactive JS/TS dependency graph visualization for VS Code",
  "publisher": "depic",
  "engines": {
    "vscode": "^1.85.0"
  },
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "depic.analyze",
        "title": "Depic: Show Dependency Graph"
      },
      {
        "command": "depic.cycles",
        "title": "Depic: Check Circular Dependencies"
      },
      {
        "command": "depic.dependents",
        "title": "Depic: Show Dependents of Current File"
      },
      {
        "command": "depic.stats",
        "title": "Depic: Show Dependency Statistics"
      }
    ]
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:run": "vitest run"
  },
  "dependencies": {
    "@depic/core": "workspace:*",
    "@depic/web": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^25.9.2",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
