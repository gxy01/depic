{
  "name": "depic-vscode",
  "displayName": "Depic — Dependency Visualizer",
  "version": "0.1.0",
  "description": "Interactive JS/TS dependency graph visualization for VS Code",
  "license": "MIT",
  "publisher": "gxy01",
  "repository": {
    "type": "git",
    "url": "https://github.com/gxy01/depic",
    "directory": "packages/vscode"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "activationEvents": [
    "onCommand:depic.analyze",
    "onCommand:depic.cycles",
    "onCommand:depic.dependents",
    "onCommand:depic.stats"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "depic.analyze",
        "title": "Depic: Show Dependency Graph"
      },
      {
        "command": "depic.cycles",
        "title": "Depic: Check Circular Dependencies"
      },
      {
        "command": "depic.dependents",
        "title": "Depic: Show Dependents of Current File"
      },
      {
        "command": "depic.stats",
        "title": "Depic: Show Dependency Statistics"
      }
    ]
  },
  "scripts": {
    "build": "tsc --emitDeclarationOnly",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:run": "vitest run"
  },
  "dependencies": {
    "@swc/core": "^1.11.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.2",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
